{
  "name": "syednexus-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx prisma/seed.ts",
    "seed:missions": "tsx prisma/seed/runMissionPacks.ts",
    "seed:attack": "tsx prisma/seed/attackLabPack001.ts",
    "seed:cyber": "tsx prisma/seed/cyberRangePack001.ts",
    "seed:games": "tsx prisma/seed/gamePack001.ts",
    "seed:practical": "tsx prisma/seed/practicalPack001.ts",
    "seed:blogs": "tsx -e \"import('dotenv/config'); import { PrismaPg } from '@prisma/adapter-pg'; import { PrismaClient } from './lib/generated/prisma/client'; import { seedBlogPack001 } from './prisma/seed/blogPack001'; const a=new PrismaPg({connectionString:process.env.DATABASE_URL}); const p=new PrismaClient({adapter:a}); seedBlogPack001(p).finally(()=>p.$disconnect());\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@google/genai": "^2.8.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@swc/helpers": "^0.5.23",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "^4.24.14",
    "otplib": "^13.4.1",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
