generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Identity {
  id Int @id @default(autoincrement())

  name String

  headline String

  summary String

  location String?

  avatar String?

  email String?

  linkedin String?

  github String?

  resume String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([id])
}

model Education {
  id Int @id @default(autoincrement())

  degree String

  institution String

  period String

  field String?

  focus String
}

model Experience {
  id Int @id @default(autoincrement())

  role String

  company String

  period String

  domain String?

  details String
}

model Skill {
  id Int @id @default(autoincrement())

  category String

  name String
}

model Certification {
  id Int @id @default(autoincrement())

  name String

  issuer String

  status String

  category String?

  skills String
}

model Project {
  id Int @id @default(autoincrement())

  name String

  category String

  status String

  description String

  technologies String
}

model Blog {
  id Int @id @default(autoincrement())

  title String

  category String

  content String

  tags String?

  date DateTime @default(now())
}

model AdminUser {
  id Int @id @default(autoincrement())

  username String @unique

  passwordHash String

  recoveryKeyHash String?

  recoveryEmail String?

  resetTokenHash String?

  resetExpires DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model AiMemory {
  id Int @id @default(autoincrement())

  category String

  content String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model User {
  id String @id @default(cuid())

  name String?

  email String @unique

  image String?

  role Role @default(USER)

  passwordHash String?

  mfaEnabled Boolean @default(false)

  mfaSecret String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  accounts Account[]

  sessions Session[]

  loginEvents LoginEvent[]

  missionProgress MissionProgress[]

  achievementUnlocks AchievementUnlock[]

  streak UserStreak?
}

model Account {
  id String @id @default(cuid())

  userId String

  type String

  provider String

  providerAccountId String

  refresh_token String?

  access_token String?

  expires_at Int?

  token_type String?

  scope String?

  id_token String?

  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id String @id @default(cuid())

  sessionToken String @unique

  userId String

  expires DateTime

  deviceId String?

  active Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginEvent {
  id Int @id @default(autoincrement())

  userId String?

  email String?

  success Boolean

  ip String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

enum Role {
  OWNER

  MANAGER

  USER
}

// =================================
// NEXUS V3 MISSION ENGINE
// =================================

model Mission {
  id Int @id @default(autoincrement())

  title String

  slug String @unique

  type String

  category String

  difficulty String

  description String

  scenario String?

  content String?

  answer String?

  explanation String?

  hints String[] @default([])

  xp Int @default(50)

  active Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  progress MissionProgress[]

  dailyChallenges DailyChallenge[]
}

model MissionProgress {
  id Int @id @default(autoincrement())

  missionId Int

  userId String

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  completed Boolean @default(false)

  score Int @default(0)

  attempts Int @default(0)

  completedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([missionId, userId])
}

// =================================
// NEXUS ACHIEVEMENT ENGINE
// =================================

model Achievement {
  id Int @id @default(autoincrement())

  name String

  description String

  icon String?

  requirement String

  xpRequired Int @default(0)

  createdAt DateTime @default(now())

  unlocked AchievementUnlock[]
}

model AchievementUnlock {
  id Int @id @default(autoincrement())

  achievementId Int

  userId String

  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  unlockedAt DateTime @default(now())

  @@unique([achievementId, userId])
}

// =================================
// NEXUS DAILY CHALLENGE
// =================================

model DailyChallenge {
  id Int @id @default(autoincrement())

  missionId Int

  date DateTime @db.Date

  createdAt DateTime @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([date])
}

model UserStreak {
  id Int @id @default(autoincrement())

  userId String @unique

  currentStreak Int @default(0)

  longestStreak Int @default(0)

  lastCompletedDate DateTime? @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =================================
// SECURITY AUDIT LOG
// =================================

model SecurityLog {
  id Int @id @default(autoincrement())

  eventType String

  severity String

  userEmail String?

  ipAddress String?

  userAgent String?

  endpoint String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
  @@index([severity])
  @@index([userEmail])
}
