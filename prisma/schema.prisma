generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}


datasource db {
  provider = "postgresql"

}

model Identity {

id Int @id @default(autoincrement())

name String

headline String

summary String

location String?

avatar String?

email String?

linkedin String?

github String?

resume String?

createdAt DateTime @default(now())

updatedAt DateTime @updatedAt

}



model Education {

id Int @id @default(autoincrement())

degree String

institution String

period String

field String?

focus String

}



model Experience {

id Int @id @default(autoincrement())

role String

company String

period String

domain String?

details String

}



model Skill {

id Int @id @default(autoincrement())

category String

name String

}



model Certification {

id Int @id @default(autoincrement())

name String

issuer String

status String

category String?

skills String

}



model Project {

id Int @id @default(autoincrement())

name String

category String

status String

description String

technologies String

}



model Blog {

id Int @id @default(autoincrement())

title String

category String

content String

tags String?

date DateTime @default(now())

}

model AdminUser {

id Int @id @default(autoincrement())


username String @unique


passwordHash String


recoveryKeyHash String?


recoveryEmail String?


resetTokenHash String?


resetExpires DateTime?


createdAt DateTime @default(now())


updatedAt DateTime @updatedAt

}
model AiMemory {

  id Int @id @default(autoincrement())

  category String

  content String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}

model User {

  id String @id @default(cuid())

  name String?

  email String @unique

  image String?

  role Role @default(USER)


  passwordHash String?


  mfaEnabled Boolean @default(false)

  mfaSecret String?


  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt


  accounts Account[]

  sessions Session[]

  loginEvents LoginEvent[]

}





model Account {

  id String @id @default(cuid())


  userId String


  type String

  provider String

  providerAccountId String


  refresh_token String?

  access_token String?

  expires_at Int?

  token_type String?

  scope String?

  id_token String?

  session_state String?


  user User @relation(fields:[userId], references:[id], onDelete:Cascade)


  @@unique([provider, providerAccountId])

}






model Session {

  id String @id @default(cuid())


  sessionToken String @unique


  userId String


  expires DateTime


  deviceId String?


  active Boolean @default(true)


  user User @relation(fields:[userId], references:[id], onDelete:Cascade)

}








model LoginEvent {

  id Int @id @default(autoincrement())


  userId String?


  email String?


  success Boolean


  ip String?


  createdAt DateTime @default(now())


  user User? @relation(fields:[userId], references:[id])

}








enum Role {

OWNER

MANAGER

USER

}
