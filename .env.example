# Database (PostgreSQL — e.g. Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# NextAuth
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Owner login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OWNER_EMAIL=your-owner@gmail.com

# Application encryption (MFA secrets, vault data)
NEXUS_SECRET=generate-a-long-random-string

# Optional — AI mentor / lab features
GOOGLE_GENERATIVE_AI_API_KEY=

# Database seed safety gate
ALLOW_DB_SEED=false

# Public site URL (SEO, sitemap)
NEXT_PUBLIC_SITE_URL=https://syednexus.com
