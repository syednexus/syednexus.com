# Database (PostgreSQL — Neon, Supabase, or self-hosted)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Owner account — Google email granted Vault / admin access
OWNER_EMAIL="you@example.com"

# Encrypts MFA secrets and signs session proofs (openssl rand -base64 32)
NEXUS_SECRET="generate-with-openssl-rand-base64-32"

# Public site URL (sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# AI mentor (Google Gemini)
GEMINI_API_KEY=""

# Lab admin password seed (development only — used by prisma seed)
ADMIN_PASSWORD="change-me-in-production"

# Database seed guard — must be "true" to run npm run seed
# ALLOW_DB_SEED="true"

# Feedback email (optional — Resend)
# RESEND_API_KEY=""
# FEEDBACK_TO_EMAIL="contact@example.com"
# FEEDBACK_FROM_EMAIL="Nexus Feedback <onboarding@resend.dev>"

# Playwright (optional)
# PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
# PLAYWRIGHT_SKIP_WEBSERVER="1"

# Upstash Redis (distributed rate limits + IP threat reputation)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Security log retention (days, default 90)
# SECURITY_LOG_RETENTION_DAYS="90"
